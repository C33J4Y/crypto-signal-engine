# Strategy (base, regime-adaptive, mean-reversion, trend-following, etc.)
STRATEGY=regime-adaptive

# Data
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
TIMEFRAMES=15m
POLL_INTERVAL_SECONDS=60
CANDLE_HISTORY_LIMIT=500

# Scoring
CONFLUENCE_THRESHOLD=7.0
RSI_PERIOD=14
RSI_OVERSOLD=35
RSI_OVERBOUGHT=65
RSI_DIVERGENCE_LOOKBACK=50
FVG_ACTIVE_LIMIT=20
VOLUME_PROFILE_LOOKBACK=100
VOLUME_PROFILE_BINS=50
VOLUME_AVG_PERIOD=20
VOLUME_SPIKE_MULTIPLIER=2.0
SMA_FAST=50
SMA_SLOW=100
SIGNAL_COOLDOWN_CANDLES=4
SIGNAL_EXPIRY_HOURS=48

# Risk Management
MIN_RISK_REWARD=2.0
TP1_RR=1.5
TP2_RR=2.5
TP3_RR=4.0
POC_PROXIMITY_PERCENT=0.3

# Notifications
WEBHOOK_DISCORD_URL=
WEBHOOK_TELEGRAM_BOT_TOKEN=
WEBHOOK_TELEGRAM_CHAT_ID=

# Server
PORT=3002
FRONTEND_PORT=5173
DB_PATH=./data/signals.db
